# Environment configuration reference for the QA automation suite.
#
# These values are NOT loaded from a .env file at runtime. They are passed
# to Maven as system properties (-D flags) or overridden in
# src/test/resources/config.properties (E2E) and karate-config.js (API).
# This file exists as documentation only.

# === E2E (Selenium) ===

# Browser to use for E2E tests
# Values: chrome (default), firefox, edge
# Usage:  mvn test -Dbrowser=firefox
BROWSER=chrome

# Run browser in headless mode
# Values: true, false (default)
# Usage:  mvn test -Dheadless=true
HEADLESS=false

# Base URL for the SauceDemo site under test
# Usage:  mvn test -DbaseUrl=https://www.saucedemo.com/
BASE_URL=https://www.saucedemo.com/

# E2E environment selector (drives baseUrl resolution in Config.java)
# Values: dev (default), staging, mock, prod
# Usage:  mvn test -Denv=staging
ENV=dev

# === API (Karate) ===

# API environment selector (drives baseUrl resolution in karate-config.js)
# Values: dev (default), staging, mock, prod
# Usage:  mvn test -Dkarate.env=staging
KARATE_ENV=dev
